# Comma-separated list of allowed frontend origins.
# Example: https://bible-art-app.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app

# SQLite file path (Render persistent disk mount recommended)
DATABASE_PATH=/var/data/bible_art.db

# true only for the first deploy to seed an empty DB.
# set to false after the first successful seed to prevent reseeding.
AUTO_SEED_DB=true
